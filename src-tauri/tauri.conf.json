{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "synonik",
  "version": "0.1.2",
  "identifier": "com.synonik.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "synonik",
        "visible": false,
        "width": 800,
        "height": 600,
        "minWidth": 360,
        "minHeight": 300,
        "decorations": false,
        "zoomHotkeysEnabled": true
      }
    ],
    "security": {
      "csp": {
        "default-src": [
          "'self'"
        ],
        "img-src": [
          "'self'"
        ],
        "style-src": [
          "'self'",
          "'unsafe-inline'"
        ],
        "script-src": [
          "'self'"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../database.sqlite": "database.sqlite"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
